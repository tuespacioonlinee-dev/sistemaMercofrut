# Copiá este archivo a `.env.test` y completá los valores reales.
# `.env.test` está en .gitignore — nunca se commitea.
#
# IMPORTANTE: TEST_DATABASE_URL DEBE apuntar a una branch dedicada de Neon
# (NUNCA a la branch de producción). El guard en tests/helpers/guard.ts
# verifica el host contra PROD_DB_HOSTS_BLOCKLIST antes de truncar tablas.

TEST_DATABASE_URL="postgresql://USER:PASSWORD@ep-XXX.region.aws.neon.tech/neondb?sslmode=require"

# Hosts de prod que el guard debe BLOQUEAR. Si TEST_DATABASE_URL apunta a
# cualquiera, los tests abortan. Incluí tanto el host pooler como el direct.
# Lista separada por comas.
PROD_DB_HOSTS_BLOCKLIST="ep-PRODUCCION.region.aws.neon.tech,ep-PRODUCCION-pooler.region.aws.neon.tech"

# URL base donde corre Next.js durante los tests (lo levanta Playwright via webServer)
TEST_BASE_URL="http://localhost:3000"

# Credenciales del usuario admin que crea el seed base.
# Estas se usan para el login UI en auth.setup.ts.
TEST_ADMIN_EMAIL="admin@test.local"
TEST_ADMIN_PASSWORD="admin-test-123"

# Secret de Auth.js (puede ser cualquier string >32 chars para tests).
AUTH_SECRET="test-secret-no-usar-en-produccion-cambiar-por-uno-real-mas-largo"
