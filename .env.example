# Base de datos — Neon PostgreSQL
# Usá la URL con pooling (la que tiene "-pooler" en el host)
# IMPORTANTE: incluí connection_limit y pool_timeout para evitar saturar
# las conexiones desde Vercel serverless (cold-starts pueden abrir muchas conexiones).
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require&connection_limit=5&pool_timeout=15"

# URL directa (sin pooler) para migraciones
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# Auth.js — generá un secreto con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-de-32-caracteres"

# URL de la app — en local: http://localhost:3000 / en Vercel: se configura automático
AUTH_URL="http://localhost:3000"

# Token compartido para el endpoint de keepalive (mantener Neon despierto en horario laboral)
# Generá uno con: openssl rand -hex 16
KEEPALIVE_SECRET="generar-secreto-aleatorio"

# ─── Datos del negocio (FALLBACK) ────────────────────────────────────────
# Estos valores se usan:
#   1. Como fallback cuando todavía no hay ParametrosNegocio en la base
#      (primer arranque). Una vez que el ADMIN completa /parametros, la
#      base pasa a ser la fuente de verdad y estos env vars se ignoran.
#   2. Como semilla por el seed (npm run seed) al onboardear un cliente
#      nuevo, así la primera pantalla ya muestra el nombre correcto.
NEXT_PUBLIC_NEGOCIO_NOMBRE="JDC Mercofrut"
NEGOCIO_RAZON_SOCIAL=""
NEGOCIO_CUIT=""
NEGOCIO_DIRECCION=""
NEGOCIO_LOCALIDAD=""
NEGOCIO_TELEFONO=""
NEGOCIO_EMAIL=""
NEGOCIO_INGRESOS_BRUTOS=""
# Una de: RESPONSABLE_INSCRIPTO, MONOTRIBUTO, EXENTO, CONSUMIDOR_FINAL, NO_RESPONSABLE
NEGOCIO_CONDICION_IVA="CONSUMIDOR_FINAL"
# Punto de venta para numeración de comprobantes
NEGOCIO_PUNTO_VENTA="1"

# ─── Seed del admin inicial (solo para `npm run seed`) ───────────────────
# Estas variables son REQUERIDAS cuando se corre el seed (primera carga).
# Después del primer login se pueden borrar; el admin queda en la base.
SEED_ADMIN_EMAIL="admin@miempresa.com"
SEED_ADMIN_PASSWORD="cambiar-en-primer-login"
SEED_ADMIN_NOMBRE="Administrador"
