generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// USUARIOS Y PERMISOS
// ============================================================================

enum RolUsuario {
  ADMIN
  VENDEDOR
  COMPRADOR
  CONSULTA
}

model Usuario {
  id           String      @id @default(cuid())
  email        String      @unique
  nombre       String
  passwordHash String
  rol          RolUsuario  @default(CONSULTA)
  activo       Boolean     @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  ventasRealizadas   Venta[]             @relation("VentaCreadaPor")
  comprasRealizadas  Compra[]            @relation("CompraCreadaPor")
  cajasAbiertas      CajaDiaria[]        @relation("CajaAbiertaPor")
  cajasCerradas      CajaDiaria[]        @relation("CajaCerradaPor")
  movimientosStock   MovimientoStock[]
  movimientosCaja    MovimientoCaja[]
  movimientosCuenta  MovimientoCuenta[]
  notasEmitidas      NotaCreditoDebito[] @relation("NotaCreadaPor")

  @@index([email])
}

// ============================================================================
// CATÁLOGO: CATEGORÍAS, UNIDADES, PRODUCTOS
// ============================================================================

model Categoria {
  id     String  @id @default(cuid())
  nombre String  @unique
  activa Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  productos Producto[]
}

model UnidadMedida {
  id          String  @id @default(cuid())
  nombre      String  @unique
  abreviatura String  @unique
  activa      Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  productos         Producto[]
  productosUnidades ProductoUnidad[]
  detallesVenta     DetalleVenta[]
  detallesCompra    DetalleCompra[]
  lineasNotaCD      LineaNotaCreditoDebito[]
}

model Producto {
  id                  String  @id @default(cuid())
  codigo              String  @unique
  nombre              String
  categoriaId         String
  unidadBaseId        String
  precioVenta         Decimal @db.Decimal(12, 2)
  precioCompra        Decimal @db.Decimal(12, 2) @default(0)
  stockTotal          Decimal @db.Decimal(12, 3) @default(0)
  stockMinimo         Decimal @db.Decimal(12, 3) @default(0)
  controlaVencimiento Boolean @default(false)
  activo              Boolean @default(true)

  categoria  Categoria    @relation(fields: [categoriaId], references: [id])
  unidadBase UnidadMedida @relation(fields: [unidadBaseId], references: [id])

  unidadesAlternativas ProductoUnidad[]
  movimientosStock     MovimientoStock[]
  detallesVenta        DetalleVenta[]
  detallesCompra       DetalleCompra[]
  lotes                LoteProducto[]
  precios              PrecioProducto[]
  lineasNotaCD         LineaNotaCreditoDebito[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([codigo])
  @@index([nombre])
  @@index([categoriaId])
}

// ============================================================================
// LISTAS DE PRECIOS
// ============================================================================
// El `precioVenta` del Producto sigue siendo el "precio base" (compatibilidad).
// Las listas permiten precios diferenciados por cliente (mayorista, minorista,
// especial). Si un cliente no tiene lista asignada o el producto no tiene
// precio en la lista, se usa el `precioVenta` del Producto como fallback.

model ListaPrecio {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  activa      Boolean  @default(true)
  esDefault   Boolean  @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  precios  PrecioProducto[]
  clientes Cliente[]
}

model PrecioProducto {
  id            String  @id @default(cuid())
  productoId    String
  listaPrecioId String
  precio        Decimal @db.Decimal(12, 2)

  producto    Producto    @relation(fields: [productoId],    references: [id], onDelete: Cascade)
  listaPrecio ListaPrecio @relation(fields: [listaPrecioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productoId, listaPrecioId])
  @@index([listaPrecioId])
}

model ProductoUnidad {
  id         String  @id @default(cuid())
  productoId String
  unidadId   String
  factor     Decimal @db.Decimal(12, 4)

  producto Producto     @relation(fields: [productoId], references: [id])
  unidad   UnidadMedida @relation(fields: [unidadId], references: [id])

  @@unique([productoId, unidadId])
}

model LoteProducto {
  id               String    @id @default(cuid())
  productoId       String
  numeroLote       String?
  fechaIngreso     DateTime  @default(now())
  fechaVencimiento DateTime?
  cantidadInicial  Decimal   @db.Decimal(12, 3)
  cantidadActual   Decimal   @db.Decimal(12, 3)
  activo           Boolean   @default(true)
  // Vinculación con la compra que creó el lote — permite revertir solo los lotes de esa compra
  origenCompraId   String?

  producto Producto @relation(fields: [productoId], references: [id])

  @@index([productoId])
  @@index([fechaVencimiento])
  @@index([origenCompraId])
}

// ============================================================================
// STOCK: MOVIMIENTOS
// ============================================================================

enum TipoMovimientoStock {
  INGRESO_COMPRA
  EGRESO_VENTA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
  DEVOLUCION_CLIENTE
  DEVOLUCION_PROVEEDOR
  EGRESO_MERMA
  EGRESO_FALTANTE
  INGRESO_SOBRANTE
}

model MovimientoStock {
  id             String              @id @default(cuid())
  productoId     String
  tipo           TipoMovimientoStock
  cantidad       Decimal             @db.Decimal(12, 3)
  stockAnterior  Decimal             @db.Decimal(12, 3)
  stockPosterior Decimal             @db.Decimal(12, 3)
  motivo         String?
  usuarioId      String
  fecha          DateTime            @default(now())

  origenTipo String?
  origenId   String?

  producto Producto @relation(fields: [productoId], references: [id])
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([productoId])
  @@index([fecha])
  @@index([origenTipo, origenId])
}

// ============================================================================
// CLIENTES Y PROVEEDORES
// ============================================================================

enum CondicionIva {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTO
  EXENTO
  CONSUMIDOR_FINAL
  NO_RESPONSABLE
}

enum TipoDocumento {
  CUIT
  CUIL
  DNI
  PASAPORTE
  OTRO
}

model Cliente {
  id                String        @id @default(cuid())
  codigo            String?       @unique
  nombreRazonSocial String
  tipoDocumento     TipoDocumento @default(DNI)
  documento         String        @unique
  condicionIva      CondicionIva  @default(CONSUMIDOR_FINAL)
  direccion         String?
  localidad         String?
  provincia         String?
  telefono          String?
  email             String?
  observaciones     String?
  maxCredito        Decimal?      @db.Decimal(14, 2)
  saldoInicial      Decimal       @db.Decimal(14, 2) @default(0)
  activo            Boolean       @default(true)
  listaPrecioId     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  cuentas     Cuenta[]
  ventas      Venta[]
  notas       NotaCreditoDebito[]
  listaPrecio ListaPrecio? @relation(fields: [listaPrecioId], references: [id])

  @@index([nombreRazonSocial])
  @@index([documento])
  @@index([listaPrecioId])
}

model Proveedor {
  id                String        @id @default(cuid())
  codigo            String?       @unique
  nombreRazonSocial String
  tipoDocumento     TipoDocumento @default(CUIT)
  documento         String        @unique
  condicionIva      CondicionIva  @default(RESPONSABLE_INSCRIPTO)
  direccion         String?
  localidad         String?
  provincia         String?
  telefono          String?
  email             String?
  observaciones     String?
  saldoInicial      Decimal       @db.Decimal(14, 2) @default(0)
  activo            Boolean       @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  cuentas Cuenta[]
  compras Compra[]

  @@index([nombreRazonSocial])
  @@index([documento])
}

// ============================================================================
// CUENTAS CORRIENTES
// ============================================================================

enum TipoCuenta {
  CONTADO
  CORRIENTE
}

enum TitularCuenta {
  CLIENTE
  PROVEEDOR
  PROPIA
}

model Cuenta {
  id          String        @id @default(cuid())
  nombre      String
  tipo        TipoCuenta
  titular     TitularCuenta
  clienteId   String?
  proveedorId String?
  saldo       Decimal       @db.Decimal(14, 2) @default(0)
  activa      Boolean       @default(true)

  cliente   Cliente?   @relation(fields: [clienteId], references: [id])
  proveedor Proveedor? @relation(fields: [proveedorId], references: [id])

  movimientos MovimientoCuenta[]
  ventas      Venta[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([clienteId])
  @@index([proveedorId])
}

enum TipoMovCuenta {
  DEBE
  HABER
  AJUSTE
}

model MovimientoCuenta {
  id             String        @id @default(cuid())
  cuentaId       String
  tipo           TipoMovCuenta
  monto          Decimal       @db.Decimal(14, 2)
  saldoAnterior  Decimal       @db.Decimal(14, 2)
  saldoPosterior Decimal       @db.Decimal(14, 2)
  descripcion    String
  fecha          DateTime      @default(now())
  usuarioId      String

  origenTipo String?
  origenId   String?
  // Idempotency para cobros y pagos repetidos
  clientRequestId String?      @unique

  cuenta  Cuenta  @relation(fields: [cuentaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([cuentaId])
  @@index([fecha])
  @@index([origenTipo, origenId])
}

// ============================================================================
// CAJA DIARIA
// ============================================================================

enum EstadoCaja {
  ABIERTA
  CERRADA
}

model CajaDiaria {
  id            String     @id @default(cuid())
  numero        Int        @unique @default(autoincrement())
  fechaApertura DateTime   @default(now())
  fechaCierre   DateTime?
  saldoInicial  Decimal    @db.Decimal(14, 2)
  saldoFinal    Decimal?   @db.Decimal(14, 2)
  saldoArqueo   Decimal?   @db.Decimal(14, 2)
  diferencia    Decimal?   @db.Decimal(14, 2)
  estado        EstadoCaja @default(ABIERTA)
  observaciones String?
  abiertaPorId  String
  cerradaPorId  String?

  // Totales por columna contable — se congela al cerrar
  totalContadoHaber Decimal? @db.Decimal(14, 2)
  totalContadoDebe  Decimal? @db.Decimal(14, 2)
  totalCCHaber      Decimal? @db.Decimal(14, 2)
  totalCCDebe       Decimal? @db.Decimal(14, 2)

  abiertaPor Usuario  @relation("CajaAbiertaPor", fields: [abiertaPorId], references: [id])
  cerradaPor Usuario? @relation("CajaCerradaPor", fields: [cerradaPorId], references: [id])

  movimientos MovimientoCaja[]

  @@index([estado])
  @@index([fechaApertura])
}

enum TipoMovCaja {
  CONTADO_DEBE
  CONTADO_HABER
  CC_DEBE
  CC_HABER
}

enum CategoriaMovCaja {
  VENTA_CONTADO
  COBRO_CLIENTE
  PAGO_PROVEEDOR
  COMPRA_CONTADO
  GASTO
  RETIRO
  DEPOSITO
  OTRO
}

model MovimientoCaja {
  id          String           @id @default(cuid())
  cajaId      String
  tipo        TipoMovCaja
  categoria   CategoriaMovCaja
  monto       Decimal          @db.Decimal(14, 2)
  descripcion String
  fecha       DateTime         @default(now())
  usuarioId   String

  origenTipo String?
  origenId   String?
  deletedAt  DateTime?

  caja    CajaDiaria @relation(fields: [cajaId], references: [id])
  usuario Usuario    @relation(fields: [usuarioId], references: [id])

  @@index([cajaId])
  @@index([fecha])
}

// ============================================================================
// VENTAS
// ============================================================================

enum EstadoVenta {
  PENDIENTE
  CONFIRMADA
  ANULADA
}

enum CondicionVenta {
  CONTADO
  CUENTA_CORRIENTE
}

model Venta {
  id              String         @id @default(cuid())
  numero          Int            @unique @default(autoincrement())
  fecha           DateTime       @default(now())
  clienteId       String
  cuentaId        String
  condicion       CondicionVenta
  subtotal        Decimal        @db.Decimal(14, 2)
  descuento       Decimal        @db.Decimal(14, 2) @default(0)
  total           Decimal        @db.Decimal(14, 2)
  estado          EstadoVenta    @default(CONFIRMADA)
  observaciones   String?
  creadaPorId     String
  anuladaEn       DateTime?
  motivoAnulacion String?
  // Idempotency: clave generada en el cliente, garantiza que reintentos no dupliquen ventas.
  clientRequestId String?        @unique

  cliente   Cliente @relation(fields: [clienteId], references: [id])
  cuenta    Cuenta  @relation(fields: [cuentaId], references: [id])
  creadaPor Usuario @relation("VentaCreadaPor", fields: [creadaPorId], references: [id])

  detalles DetalleVenta[]
  remitos  Remito[]
  facturas Factura[]
  notas    NotaCreditoDebito[]

  @@index([fecha])
  @@index([clienteId])
  @@index([estado])
}

model DetalleVenta {
  id             String  @id @default(cuid())
  ventaId        String
  productoId     String
  unidadId       String
  cantidad       Decimal @db.Decimal(12, 3)
  cantidadBase   Decimal @db.Decimal(12, 3)
  precioUnitario Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(14, 2)

  venta    Venta        @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto     @relation(fields: [productoId], references: [id])
  unidad   UnidadMedida @relation(fields: [unidadId], references: [id])

  @@index([ventaId])
  @@index([productoId])
}

// ============================================================================
// COMPRAS
// ============================================================================

enum EstadoCompra {
  PENDIENTE
  RECIBIDA
  ANULADA
}

enum CondicionCompra {
  CONTADO
  CUENTA_CORRIENTE
}

enum TipoComprobanteCompra {
  FACTURA_A
  FACTURA_B
  FACTURA_C
  FACTURA_E
  REMITO
  TICKET
  OTRO
}

model Compra {
  id                String                 @id @default(cuid())
  numeroComprobante String?
  tipoComprobante   TipoComprobanteCompra?
  puntoVenta        Int?
  fecha             DateTime               @default(now())
  proveedorId       String
  condicion         CondicionCompra
  subtotal          Decimal                @db.Decimal(14, 2)
  iva               Decimal                @db.Decimal(14, 2) @default(0)
  descuento         Decimal                @db.Decimal(14, 2) @default(0)
  total             Decimal                @db.Decimal(14, 2)
  estado            EstadoCompra           @default(RECIBIDA)
  observaciones     String?
  creadaPorId       String
  anuladaEn         DateTime?
  motivoAnulacion   String?
  clientRequestId   String?                @unique

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  creadaPor Usuario   @relation("CompraCreadaPor", fields: [creadaPorId], references: [id])

  detalles DetalleCompra[]

  @@index([fecha])
  @@index([proveedorId])
  @@index([estado])
}

model DetalleCompra {
  id             String  @id @default(cuid())
  compraId       String
  productoId     String
  unidadId       String
  cantidad       Decimal @db.Decimal(12, 3)
  cantidadBase   Decimal @db.Decimal(12, 3)
  precioUnitario Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(14, 2)

  compra   Compra       @relation(fields: [compraId], references: [id], onDelete: Cascade)
  producto Producto     @relation(fields: [productoId], references: [id])
  unidad   UnidadMedida @relation(fields: [unidadId], references: [id])

  @@index([compraId])
  @@index([productoId])
}

// ============================================================================
// REMITOS Y FACTURAS
// ============================================================================

model ParametrosComprobante {
  id              String   @id @default(cuid())
  puntoVenta      Int      @unique @default(1)
  proximoRemito   Int      @default(1)
  proximaFacturaA Int      @default(1)
  proximaFacturaB Int      @default(1)
  proximaFacturaC Int      @default(1)
  updatedAt       DateTime @updatedAt
}

enum EstadoRemito {
  EMITIDO
  ANULADO
}

model Remito {
  id              String       @id @default(cuid())
  numero          String       @unique
  puntoVenta      Int
  fecha           DateTime     @default(now())
  ventaId         String
  estado          EstadoRemito @default(EMITIDO)
  anuladoEn       DateTime?
  motivoAnulacion String?

  venta    Venta     @relation(fields: [ventaId], references: [id])
  facturas Factura[]

  @@index([ventaId])
  @@index([fecha])
}

enum TipoFactura {
  A
  B
  C
  NOTA_CREDITO_A
  NOTA_CREDITO_B
  NOTA_CREDITO_C
  NOTA_DEBITO_A
  NOTA_DEBITO_B
  NOTA_DEBITO_C
}

enum EstadoFactura {
  EMITIDA
  ANULADA
  RECHAZADA_ARCA
}

model Factura {
  id            String        @id @default(cuid())
  numero        String        @unique
  puntoVenta    Int
  tipo          TipoFactura
  fechaEmision  DateTime      @default(now())
  ventaId       String
  remitoId      String?
  subtotal      Decimal       @db.Decimal(14, 2)
  iva           Decimal       @db.Decimal(14, 2) @default(0)
  total         Decimal       @db.Decimal(14, 2)
  estado        EstadoFactura @default(EMITIDA)

  cae            String?
  caeVencimiento DateTime?
  qrUrl          String?
  arcaRespuesta  Json?

  venta  Venta   @relation(fields: [ventaId], references: [id])
  remito Remito? @relation(fields: [remitoId], references: [id])

  @@index([ventaId])
  @@index([fechaEmision])
  @@index([cae])
}

// ============================================================================
// NOTAS DE CRÉDITO Y DÉBITO (Bloque B)
// ============================================================================
//
// Notas comerciales (no fiscales) emitidas contra una Venta existente.
// - Nota de CRÉDITO: resta deuda al cliente, opcionalmente devuelve stock.
// - Nota de DÉBITO: suma deuda al cliente (cargo adicional, sin stock).
// Cuando se implemente facturación real, este modelo se extenderá con un
// `facturaOrigenId` opcional sin breaking change.

enum TipoNota {
  CREDITO
  DEBITO
}

enum EstadoNota {
  EMITIDA
  ANULADA
}

model NotaCreditoDebito {
  id              String           @id @default(cuid())
  tipo            TipoNota
  letra           LetraComprobante
  numero          String           @unique
  puntoVenta      Int
  fecha           DateTime         @default(now())
  ventaOrigenId   String
  clienteId       String
  motivo          String
  montoTotal      Decimal          @db.Decimal(14, 2)
  estado          EstadoNota       @default(EMITIDA)
  creadaPorId     String
  anuladaEn       DateTime?
  motivoAnulacion String?
  clientRequestId String?          @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  ventaOrigen Venta   @relation(fields: [ventaOrigenId], references: [id])
  cliente     Cliente @relation(fields: [clienteId],     references: [id])
  creadaPor   Usuario @relation("NotaCreadaPor", fields: [creadaPorId], references: [id])

  lineas LineaNotaCreditoDebito[]

  @@index([ventaOrigenId])
  @@index([clienteId])
  @@index([fecha])
  @@index([estado])
}

model LineaNotaCreditoDebito {
  id                    String  @id @default(cuid())
  notaId                String
  productoId            String
  unidadId              String
  cantidad              Decimal @db.Decimal(12, 3)
  cantidadBase          Decimal @db.Decimal(12, 3)
  precioUnitario        Decimal @db.Decimal(12, 2)
  subtotal              Decimal @db.Decimal(14, 2)
  generaMovimientoStock Boolean @default(true)

  nota     NotaCreditoDebito @relation(fields: [notaId], references: [id], onDelete: Cascade)
  producto Producto          @relation(fields: [productoId], references: [id])
  unidad   UnidadMedida      @relation(fields: [unidadId],   references: [id])

  @@index([notaId])
  @@index([productoId])
}

// ============================================================================
// SECUENCIA DE COMPROBANTES (numeración robusta y atómica)
// ============================================================================
//
// Reemplaza los contadores hardcodeados en `ParametrosComprobante`
// (proximoRemito / proximaFacturaA / proximaFacturaB / proximaFacturaC) por
// una tabla genérica que soporta todos los tipos × letras × puntos de venta.
//
// La generación del próximo número va por src/server/lib/numeracion.ts y debe
// ejecutarse dentro de la misma $transaction que crea el comprobante, así si
// la transacción falla el contador no queda incrementado.

enum TipoComprobante {
  REMITO
  FACTURA
  NOTA_CREDITO
  NOTA_DEBITO
  RECIBO
}

enum LetraComprobante {
  A
  B
  C
  X    // sin letra fiscal (remitos, recibos internos)
}

model SecuenciaComprobante {
  id           String           @id @default(cuid())
  tipo         TipoComprobante
  letra        LetraComprobante
  puntoVenta   Int
  ultimoNumero Int              @default(0)
  updatedAt    DateTime         @updatedAt

  @@unique([tipo, letra, puntoVenta])
  @@index([puntoVenta])
}

// ============================================================================
// PARÁMETROS GENERALES
// ============================================================================

model ParametrosNegocio {
  id                    String       @id @default(cuid())
  nombreFantasia        String
  razonSocial           String
  cuit                  String
  condicionIva          CondicionIva
  direccion             String
  localidad             String
  telefono              String?
  email                 String?
  logoUrl               String?
  ingresosBrutos        String?
  inicioActividades     DateTime?
  facturacionHabilitada Boolean      @default(false)

  updatedAt DateTime @updatedAt
}
